{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoboSats.Exp",
  "version": "../../package.json",
  "identifier": "org.robosats.experimental",
  "build": {
    "frontendDist": "../../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splash",
        "title": "RoboSats Exp.",
        "url": "desktop/splash.html",
        "width": 390,
        "height": 520,
        "center": true,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "backgroundColor": "#0b1320"
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: data: blob: http: https:; connect-src 'self' ipc: http: https: ws: wss:; media-src 'self' data: blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "capabilities": [
        "main"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "shortDescription": "Private peer-to-peer Bitcoin trading",
    "longDescription": "RoboSats Experimental desktop client with an embedded Arti connection.",
    "externalBin": [
      "binaries/robosats-arti"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    },
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
